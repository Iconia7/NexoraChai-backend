generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                 String          @id @default(cuid())
  email              String          @unique
  password           String
  twoFactorEnabled   Boolean         @default(false)
  twoFactorSecret    String?
  isVerified         Boolean         @default(false)
  otp                String?
  otpExpires         DateTime?
  resetToken         String?         @unique
  resetTokenExpires  DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  profile            CreatorProfile?
}

model CreatorProfile {
  id                     String               @id @default(cuid())
  userId                 String               @unique
  user                   User                 @relation(fields: [userId], references: [id])
  username               String               @unique
  displayName            String
  bio                    String?
  avatarUrl              String?
  mpesaNumber            String?
  paystackSubaccountCode String?
  socialLinks            String?              // JSON string: { twitter, github, etc }
  category               String?              // e.g. Artist, Developer, etc
  views                  Int                  @default(0)
  wallet                 CreatorWallet?
  transactions           PaymentTransaction[]
  notifications          Notification[]
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
}

model CreatorWallet {
  id        String         @id @default(cuid())
  creatorId String         @unique
  creator   CreatorProfile @relation(fields: [creatorId], references: [id])
  balance   Float          @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model PaymentTransaction {
  id               String         @id @default(cuid())
  creatorId        String
  creator          CreatorProfile @relation(fields: [creatorId], references: [id])
  type             String         @default("TIP") // TIP, WITHDRAWAL
  grossAmount      Float          // Total requested/paid
  nexoraFee        Float          @default(0) // Platform fee for tips
  networkFee       Float          @default(0) // Safaricom B2C fee for withdrawals
  netAmount        Float          // grossAmount - (nexoraFee or networkFee)
  currency         String         @default("KES")
  fanName          String?
  fanMessage       String?
  gateway          String         @default("MPESA") // MPESA or PAYSTACK
  gatewayReference String?        @unique // paystack reference or daraja CheckoutRequestID or B2C OriginatorConversationID
  status           String         @default("PENDING") // PENDING, COMPLETED, FAILED
  source           String?        // twitter, instagram, direct, etc
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Notification {
  id        String         @id @default(cuid())
  creatorId String
  creator   CreatorProfile @relation(fields: [creatorId], references: [id])
  type      String         @default("INFO") // INFO, SUCCESS, WARNING, ERROR
  title     String
  message   String
  isRead    Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}
